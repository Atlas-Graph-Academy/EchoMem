# openclaw-skills runtime config
# Copy to .env.local and fill real credentials.

# =========================================================
# Profile 1: EchoMem-only (ingestion, chat, identity, signals)
# =========================================================
ECHOMEM_BASE_URL=http://localhost:3000
ECHOMEM_API_KEY=ec_replace_me
OPENCLAW_MEMORY_DIR=/absolute/path/to/openclaw/memory

# memory-graph backend mode:
# - extension: use EchoMem extension endpoints
# - iditor_user: use WebPageReactVersion user-memory endpoints
GRAPH_BACKEND=extension

# =========================================================
# Profile 2: Social stack (connect, match, network, community)
# =========================================================
MEMORY_FEED_BASE_URL=http://localhost:8787
MERCURY_BASE_URL=http://localhost:8788
MERCURY_AUTH_TOKEN=

# =========================================================
# Profile 3: Iditor user graph mode (optional)
# Only needed when GRAPH_BACKEND=iditor_user
# =========================================================
IDITOR_BASE_URL=
IDITOR_AUTH_TOKEN=
